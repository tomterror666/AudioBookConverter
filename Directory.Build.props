<?xml version="1.0" encoding="utf-8"?>
<Project>
  <!--
    WinUI2xVersion (repo-wide): keeps Microsoft.UI.Xaml off 2.8 defaults for node_modules projects.
    AudioBookConverter.vcxproj also pins Microsoft.WindowsAppSDK 1.6.x — WinUI 2.7 alone can still transitively pull WASDK 1.7 (WMC9999).

    This file must be committed to Git — a fresh clone without it will hit WMC9999 again.

    RestoreLockedMode=false: RNW ships packages.lock.json; with WinUI2xVersion 2.7.3 the lock can disagree (NU1004).
    Do not set RestorePackagesWithLockFile=false — NuGet NU1005 if a packages.lock.json exists.
  -->
  <PropertyGroup>
    <WinUI2xVersion>2.7.3</WinUI2xVersion>
    <RestoreLockedMode>false</RestoreLockedMode>
  </PropertyGroup>

  <!-- dotnet msbuild /restore: OutDir can be empty when Bundle.props runs; RNW Bundle.props line 54 calls GetFullPath(OutDir) → MSB4184. -->
  <PropertyGroup Condition="'$(MSBuildProjectExtension)' == '.vcxproj' And '$(OutDir)' == ''">
    <OutDir Condition="'$(Configuration)' != '' And '$(Platform)' != ''">$(Platform)\$(Configuration)\</OutDir>
    <OutDir Condition="'$(OutDir)' == '' And '$(Configuration)' != ''">$(Configuration)\</OutDir>
    <OutDir Condition="'$(OutDir)' == ''">bin\</OutDir>
  </PropertyGroup>
</Project>
