{
  "name": "AudioBookConverter",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "postinstall": "patch-package && node scripts/patch-wasdk-xaml-interop.mjs",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "test:unit": "jest --watchman=false --testPathIgnorePatterns=App.ui.test",
    "test:coverage": "jest --coverage --watchman=false",
    "test:ui:app": "jest --runInBand --watchman=false src/App.ui.test.tsx",
    "icons": "node scripts/generate-app-icons.mjs",
    "windows": "npx @react-native-community/cli run-windows",
    "windows:sln-dotnet": "node scripts/msbuild-windows-sln.mjs ./windows/AudioBookConverter.sln /restore /t:Build /p:Configuration=Debug /p:Platform=x64 /p:AppxBundle=Never /p:RunAutolinkCheck=false /p:PlatformToolset=v143 /p:DefaultPlatformToolset=v143 /m",
    "macos:release": "cd macos && xcodebuild -workspace AudioBookConverter.xcworkspace -scheme AudioBookConverter-macOS -configuration Release -derivedDataPath ./build"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-native": "0.77.3",
    "react-native-file-panel": "^1.2.0",
    "react-native-macos": "0.77.7",
    "react-native-svg": "15.11.1",
    "react-native-windows": "0.77.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "15.0.1",
    "@react-native-community/cli-platform-android": "15.0.1",
    "@react-native-community/cli-platform-ios": "15.0.1",
    "@react-native/babel-preset": "0.77.3",
    "@react-native/eslint-config": "0.77.3",
    "@react-native/metro-config": "0.77.3",
    "@react-native/typescript-config": "0.77.3",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^18.2.6",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.6.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "metro-config": "^0.81.5",
    "patch-package": "^8.0.1",
    "prettier": "2.8.8",
    "react-test-renderer": "18.3.1",
    "sharp": "^0.33.5",
    "typescript": "5.0.4"
  },
  "engines": {
    "node": ">=18"
  },
  "react-native-windows": {
    "init-windows": {
      "name": "AudioBookConverter",
      "namespace": "AudioBookConverter",
      "template": "old/uwp-cpp-app"
    }
  }
}
